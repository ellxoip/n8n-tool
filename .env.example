# n8n runtime
N8N_USER_FOLDER=./.runtime/n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=false
N8N_DIAGNOSTICS_ENABLED=false
# Keep false unless @n8n/task-runner-python is available in your n8n install.
N8N_PYTHON_ENABLED=false

# CLI
N8N_BASE_URL=http://localhost:5678
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CREDENTIAL_NAME=Ollama Local
N8N_TEAM_TIMEOUT_MS=300000
PYTHON_PATH=./.runtime/python311/python.exe

# Only needed for import/update scripts.
# Generate this in n8n and keep it private.
N8N_API_KEY=
